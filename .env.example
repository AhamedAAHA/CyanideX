# ─────────────────────────────────────────────────────────────
#  CyanideX — Environment Configuration
#  Copy this file to ".env" and fill in your credentials.
#  All integrations gracefully fall back to simulated intel
#  data when keys are missing, so the OS runs out of the box.
# ─────────────────────────────────────────────────────────────

# Server
PORT=4000
NODE_ENV=development

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Bright Data (OSINT collection)
BRIGHTDATA_API_TOKEN=
BRIGHTDATA_ZONE=
BRIGHTDATA_BASE_URL=https://api.brightdata.com

# AIML API (threat forecasting / LLM analysis)
AIML_API_KEY=
AIML_BASE_URL=https://api.aimlapi.com/v1
AIML_MODEL=gpt-4o-mini

# Speechmatics (voice intelligence)
SPEECHMATICS_API_KEY=
SPEECHMATICS_BASE_URL=https://asr.api.speechmatics.com/v2

# Feature flags
USE_FALLBACK_DATA=true
