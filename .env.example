# ─────────────────────────────────────────────────────────────
#  CyanideX — Environment Configuration
#  Copy to ".env" locally. On Vercel, set these in Project Settings.
# ─────────────────────────────────────────────────────────────

# Server
PORT=4000
NODE_ENV=production

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Bright Data SERP API (OSINT collection)
BRIGHT_DATA_API_KEY=
BRIGHT_DATA_SERP_ZONE=
BRIGHTDATA_BASE_URL=https://api.brightdata.com

# AIML API
AIML_API_KEY=
AIML_BASE_URL=https://api.aimlapi.com/v1
AIML_MODEL_ANALYSIS=gpt-4o-mini
AIML_MODEL_CHAT=gpt-4o
AIML_MODEL_SEARCH=gpt-4o-search-preview
AIML_MODEL_SEARCH_MINI=gpt-4o-mini-search-preview
AIML_SEARCH_CONTEXT_SIZE=medium
AIML_MODEL_INTENT=gpt-4o-mini
AIML_MODEL_WORLD=gpt-4o
AIML_MODEL_VISION=gpt-4o
AIML_MODEL_TRANSCRIBE=whisper-1
AIML_TTS_MODEL=openai/tts-1
AIML_TTS_VOICE=nova
AIML_TTS_SPEED=1.08

# Speechmatics
SPEECHMATICS_API_KEY=
SPEECHMATICS_BASE_URL=https://asr.api.speechmatics.com/v2
SPEECHMATICS_TTS_VOICE=sarah

# Feature flags
USE_FALLBACK_DATA=true
